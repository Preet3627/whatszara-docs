{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/components/layout,_N_T_/docs/components/page,_N_T_/docs/components"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/components/__PAGE__",
    "/docs/components",
    "/docs",
    "/_index",
    "/_head"
  ]
}