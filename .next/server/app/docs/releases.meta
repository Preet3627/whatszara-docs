{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/releases/layout,_N_T_/docs/releases/page,_N_T_/docs/releases"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/releases/__PAGE__",
    "/docs/releases",
    "/docs",
    "/_index",
    "/_head"
  ]
}