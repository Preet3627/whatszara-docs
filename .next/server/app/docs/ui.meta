{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/docs/layout,_N_T_/docs/ui/layout,_N_T_/docs/ui/page,_N_T_/docs/ui"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/docs/ui/__PAGE__",
    "/docs/ui",
    "/docs",
    "/_index",
    "/_head"
  ]
}